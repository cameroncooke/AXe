+    };
+    ((void (*)(id, SEL, double, id))objc_msgSend)(session, loadSelector, timeout, loadReply);
+    if (dispatch_semaphore_wait(loadSemaphore, dispatch_time(DISPATCH_TIME_NOW, (int64_t)((timeout + 1) * NSEC_PER_SEC))) != 0) {
